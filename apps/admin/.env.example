# =============================================================================
# Olimpo Admin — variables de entorno
# Copiar a .env y rellenar antes de arrancar.
# NUNCA subir .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase del panel Superadmin
# Puede ser la misma instancia que el primer tenant (MVP con un solo tenant)
# o una instancia Supabase dedicada al Superadmin.
# -----------------------------------------------------------------------------
ADMIN_SUPABASE_URL=https://tu-proyecto.supabase.co
ADMIN_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# Autenticación del Superadmin
# API key estática que protege todos los endpoints.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
# -----------------------------------------------------------------------------
ADMIN_API_KEY=cambia-esto-por-una-clave-segura

# -----------------------------------------------------------------------------
# Cifrado de service_role_keys de los tenants
# Clave Fernet (AES-128-CBC + HMAC-SHA256).
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CRÍTICO: si se pierde esta clave, no se pueden descifrar las keys de los tenants.
# -----------------------------------------------------------------------------
ADMIN_ENCRYPTION_KEY=genera-una-clave-fernet-aqui

# -----------------------------------------------------------------------------
# IPs permitidas (separadas por coma)
# Solo estas IPs pueden conectarse al panel Admin.
# En desarrollo usar 127.0.0.1. En producción, la IP fija de tu equipo/VPN.
# -----------------------------------------------------------------------------
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
ENVIRONMENT=development
