# =============================================================================
# Olimpo API — Variables de entorno
# Copiar a .env y completar con valores reales.
# Nunca comitear .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# JWT Secret: Project Settings → API → JWT Secret en el dashboard de Supabase
SUPABASE_JWT_SECRET=your-jwt-secret-here

# -----------------------------------------------------------------------------
# LLMs (via LiteLLM — nunca llamar directamente a OpenAI/Anthropic)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
RUNPOD_API_KEY=...
RUNPOD_ENDPOINT_OCR=https://api.runpod.ai/v2/<endpoint-id>

# -----------------------------------------------------------------------------
# Google Workspace (Domain-Wide Delegation para Gmail API)
# -----------------------------------------------------------------------------
# JSON completo de la cuenta de servicio, serializado como string
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_WORKSPACE_DOMAIN=tudominio.com.mx

# -----------------------------------------------------------------------------
# Observabilidad
# -----------------------------------------------------------------------------
LOGFIRE_TOKEN=...
SENTRY_DSN=https://...@sentry.io/...

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
ENVIRONMENT=development
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Umbrales de IA (fallback si configuracion_sistema no tiene el valor)
# Los valores canónicos viven en la tabla configuracion_sistema de la DB.
# Estos env vars son solo el fallback para el arranque inicial.
# -----------------------------------------------------------------------------
CONFIDENCE_AGENTE=0.75
CONFIDENCE_DOCUMENTO=0.70
CONFIDENCE_VINCULACION=0.85
FUZZY_MATCH_NOMBRE=0.85
TIMEOUT_PASSWORD_HORAS=24
