# =============================================================================
# Olimpo Web — variables de entorno
# Copiar a .env.local y rellenar.
# NUNCA subir .env.local al repositorio.
# =============================================================================

# URL del proyecto Supabase de ESTE tenant.
# Cada promotoría tiene su propio proyecto Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon key (safe para exponer en el navegador).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL del API de este mismo tenant (para llamadas desde el servidor).
NEXT_PUBLIC_API_URL=http://localhost:8000
