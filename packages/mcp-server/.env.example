# =============================================================================
# Olimpo MCP Server — Variables de entorno
# Copiar a .env y completar. Nunca comitear .env.
# =============================================================================

# Supabase — usar SERVICE ROLE KEY (los agentes bypasan RLS intencionalmente)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Nombre del servidor MCP (aparece en clientes como Claude Desktop)
MCP_SERVER_NAME=Olimpo CRM

# Entorno
ENVIRONMENT=development
